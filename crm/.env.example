SECRET_KEY=your-secret-key-here
DEBUG=False
DATABASE_URL=postgres://user:password@host:5432/dbname

# Render hostname (set automatically by Render as RENDER_EXTERNAL_HOSTNAME)
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# Cloudinary — REQUIRED for image uploads on Render (ephemeral filesystem)
# Without these, images will be saved to disk and wiped on every deploy.
# Set these in Render Dashboard → Environment Variables
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
